package com.capg.jobportal.listener;

import com.capg.jobportal.event.JobPostedEvent;
import com.capg.jobportal.service.EmailService;
import org.springframework.amqp.rabbit.annotation.RabbitListener;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.core.ParameterizedTypeReference;
import org.springframework.http.HttpMethod;
import org.springframework.http.ResponseEntity;
import org.springframework.stereotype.Component;
import org.springframework.web.client.RestTemplate;

import java.util.List;

@Component
public class JobPostedListener {

    @Autowired
    private EmailService emailService;

    @Autowired
    private RestTemplate restTemplate;

    @Value("${auth.service.url}")
    private String authServiceUrl;

    // This method runs automatically whenever a message arrives in the queue
    @RabbitListener(queues = "${rabbitmq.queue}")
    public void handleJobPosted(JobPostedEvent event) {
        System.out.println("Received job posted event: " + event.getTitle());

        try {
            // Call Auth Service to get all job seeker emails
            String url = authServiceUrl + "/api/internal/users/job-seeker-emails";

            ResponseEntity<List<String>> response = restTemplate.exchange(
                    url,
                    HttpMethod.GET,
                    null,
                    new ParameterizedTypeReference<List<String>>() {}
            );

            List<String> emails = response.getBody();

            if (emails != null && !emails.isEmpty()) {
                System.out.println("Sending email to " + emails.size() + " job seekers");
                for (String email : emails) {
                    try {
                        emailService.sendJobAlert(email, event);
                        System.out.println("Email sent to: " + email);
                    } catch (Exception e) {
                        System.err.println("Failed to send email to " + email + ": " + e.getMessage());
                    }
                }
            }
        } catch (Exception e) {
            System.err.println("Error processing job posted event: " + e.getMessage());
        }
    }
}
