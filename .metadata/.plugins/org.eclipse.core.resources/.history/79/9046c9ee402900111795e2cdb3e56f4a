server:
  port: 8083

spring:
  application:
    name: application-service

  datasource:
    url: jdbc:mysql://jobportal-db:3306/jobportal_db?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
    username: ${APPLICATION_SERVICE_DB_USERNAME}
    password: ${APPLICATION_SERVICE_DB_PASSWORD}
    driver-class-name: com.mysql.cj.jdbc.Driver

  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
    defer-datasource-initialization: true
    properties:
      hibernate:
        dialect: org.hibernate.dialect.MySQLDialect
        format_sql: true

  servlet:
    multipart:
      max-file-size: 10MB
      max-request-size: 11MB

  autoconfigure:
    exclude:
      - org.springframework.boot.autoconfigure.security.servlet.UserDetailsServiceAutoConfiguration

  rabbitmq:
    host: rabbitmq
    port: 5672
    username: guest
    password: guest

rabbitmq:
  exchange: jobportal.exchange
  queue: job.applied.queue
  routing-key: job.applied

eureka:
  client:
    service-url:
      defaultZone: http://eureka-server:8761/eureka/
  instance:
    prefer-ip-address: true

cloudinary:
  cloud-name: ${APPLICATION_SERVICE_CLOUDINARY_CLOUD_NAME}
  api-key: ${APPLICATION_SERVICE_CLOUDINARY_API_KEY}
  api-secret: ${APPLICATION_SERVICE_CLOUDINARY_API_SECRET}

management:
  endpoints:
    web:
      exposure:
        include: health, info
